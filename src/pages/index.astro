---
import App from '../App.jsx';
import '../styles/tokens.css';
import '../index.css';

// Deployed under /havruta/. Asset references in raw HTML are prefixed with the
// configured base so the favicon and icon resolve on GitHub Pages.
const base = import.meta.env.BASE_URL;
const favicon = `${base}favicon.svg`;
const appleTouchIcon = `${base}icons/apple-touch-icon.png`;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0A3255" />
    <title>Havruta</title>

    <!-- Set the saved theme before first paint so there is no flash. -->
    <script is:inline>(function(){var t=localStorage.getItem('havruta-theme')||'dark';document.documentElement.setAttribute('data-theme',t)})()</script>

    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="apple-touch-icon" href={appleTouchIcon} />

    <!-- Fonts from Google Fonts: headline, body, scholarly serif, mono, and Hebrew. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&family=Roboto:wght@400;500&family=Crimson+Text:ital,wght@0,400;0,600;1,400&family=Roboto+Mono:wght@400&family=Frank+Ruhl+Libre:wght@400;500;700&family=Noto+Serif+Hebrew:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div id="root">
      <App client:only="react" />
    </div>
  </body>
</html>
